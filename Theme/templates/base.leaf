<!DOCTYPE html>
<html lang="#(language.locale)">
<head>
    <meta charset="UTF-8">
    <!-- Warm the connection to the design system origin (render-blocking CSS + fonts). -->
    <link rel="preconnect" href="https://design.vapor.codes">
    <link rel="preconnect" href="https://design.vapor.codes" crossorigin>
    <meta property="og:site_name" content="#(site.name)">
    <meta property="og:type" content="#if(blogPost):article#else:website#endif">
    <meta property="og:locale" content="#(language.ogLocale)">
    <link rel="canonical" href="#(page.canonicalURL)">
    <meta name="twitter:url" content="#(page.canonicalURL)">
    <meta property="og:url" content="#(page.canonicalURL)">
    <title>#if(page.isHome):#(site.name) Blog#else:#if(page.titleLength > 50):#(page.title)#else:#(page.title) | #(site.name)#endif#endif</title>
    <meta name="twitter:title" content="#if(page.isHome):#(site.name) Blog#else:#(page.title)#endif">
    <meta property="og:title" content="#if(page.isHome):#(site.name) Blog#else:#(page.title)#endif">
    #if(page.description):<meta name="description" content="#(page.description)">
    <meta name="twitter:description" content="#(page.description)">
    <meta property="og:description" content="#(page.description)">#endif
    <meta name="twitter:card" content="summary_large_image">
    #if(site.twitterSite):<meta name="twitter:site" content="#(site.twitterSite)">
    <meta name="twitter:creator" content="#(site.twitterSite)">#endif
    #if(page.imageURL):<meta property="og:image" content="#(page.imageURL)">
    <meta property="og:image:alt" content="#if(page.isHome):#(site.name) Blog#else:#(page.title)#endif">
    #if(page.imageType):<meta property="og:image:type" content="#(page.imageType)">#endif
    <meta name="twitter:image" content="#(page.imageURL)">
    <meta name="twitter:image:alt" content="#if(page.isHome):#(site.name) Blog#else:#(page.title)#endif">#endif
    #if(blogPost):<meta property="article:published_time" content="#(blogPost.isoDateTime)">
    #for(author in blogPost.authors):<meta property="article:author" content="#(author.name)">
    #endfor#for(tag in blogPost.tags):<meta property="article:tag" content="#(tag.name)">
    #endfor#endif
    <link rel="alternate" type="application/rss+xml" title="#(site.name) Blog" href="/feed.rss">
    <link rel="stylesheet" href="https://design.vapor.codes/main.css" type="text/css">
    <script src="https://design.vapor.codes/js/detectColorScheme.js"></script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="color-scheme" content="light dark">
    <link rel="icon" href="https://design.vapor.codes/favicons/favicon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" sizes="180x180" href="https://design.vapor.codes/favicons/apple-touch-icon.png">
    <link rel="icon" sizes="96x96" href="https://design.vapor.codes/favicons/favicon-96x96.png" type="image/png">
    <link rel="manifest" href="https://design.vapor.codes/favicons/site.webmanifest">
    <link rel="shortcut icon" href="https://design.vapor.codes/favicons/favicon.ico">
    <meta name="apple-mobile-web-app-title" content="#(site.name)">
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)">
    <meta name="theme-color" content="#141416" media="(prefers-color-scheme: dark)">
    #if(page.structuredData):<script type="application/ld+json">#unsafeHTML(page.structuredData)</script>#endif
</head>
<body>
    <a class="kiln-skip-link" href="#main-content">#(strings.skipToContent)</a>
    #extend("partials/header")
    <main id="main-content" tabindex="-1">#import("content")</main>
    #extend("partials/footer")
    <script src="https://design.vapor.codes/main.js"></script>
</body>
</html>
